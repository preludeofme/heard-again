FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

LABEL build.version="2026-05-30-slim"

ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1
ENV HF_HUB_OFFLINE=0
ENV MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
ENV HF_HOME=/runpod-volume/models/huggingface
ENV TRANSFORMERS_CACHE=/runpod-volume/models/huggingface
ENV TORCH_HOME=/runpod-volume/models/torch
ENV MODEL_CACHE_DIR=/runpod-volume/models
ENV TEMP_DIR=/tmp/heard-again
ENV DEFAULT_AUDIO_FORMAT=wav

WORKDIR /app

# Install minimal system deps for audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    sox \
    libsox-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first (Docker layer caching)
COPY requirements.slim.txt .
COPY torchaudio_ext_patch.py /tmp/torchaudio_ext_patch.py

# Install torch 2.4.1 is already in the base image
# Install python deps
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.slim.txt \
    && pip install torchaudio==2.4.0 --no-deps \
    && python3 -c "\
import site, os, shutil;\
[shutil.copy('/tmp/torchaudio_ext_patch.py', p) or print('Patched', p)\
 for sp in site.getsitepackages()\
 for p in [os.path.join(sp, 'torchaudio', '_extension', '__init__.py')]\
 if os.path.exists(p)]" \
    || echo "torchaudio patch optional - continuing"

# RunPod SDK + Qwen3-TTS
RUN pip install runpod boto3 requests nvidia-ml-py \
    && git clone --depth 1 https://github.com/QwenLM/Qwen3-TTS.git /tmp/qwen3-tts \
    && echo "=== qwen3-tts pinned commit: $(git -C /tmp/qwen3-tts rev-parse HEAD) ===" \
    && pip install --no-deps /tmp/qwen3-tts \
    && pip install "sox" "onnxruntime" \
    && rm -rf /tmp/qwen3-tts \
    # Clean pip cache to save space
    && rm -rf /root/.cache/pip

# Create volume dirs but DON'T pre-download the model
# Model will be lazy-downloaded on first request or via pre-warm
RUN mkdir -p /runpod-volume/models/huggingface /tmp/heard-again \
    && chmod -R 777 /runpod-volume /tmp/heard-again

COPY app/ ./app/

CMD ["python", "-m", "app.runpod_handler"]
