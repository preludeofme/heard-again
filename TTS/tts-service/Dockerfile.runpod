FROM nvcr.io/nvidia/pytorch:25.12-py3

LABEL build.version="2026-05-29.5"

# Cache-bust marker — bump to force rebuild of layers below
ARG CACHE_BUST=2

ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1
ENV MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
ENV HF_HOME=/runpod-volume/models/huggingface
ENV TRANSFORMERS_CACHE=/runpod-volume/models/huggingface
ENV TORCH_HOME=/runpod-volume/models/torch
ENV MODEL_CACHE_DIR=/runpod-volume/models
ENV TEMP_DIR=/tmp/heard-again
ENV DEFAULT_AUDIO_FORMAT=wav

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    sox \
    libsox-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
COPY torchaudio_ext_patch.py /tmp/torchaudio_ext_patch.py

# Install torchaudio with --no-deps to avoid pulling PyPI torch (which would replace
# NGC's CUDA 13.1 build with a CUDA 12.x build, breaking Blackwell support).
# Then replace _extension/__init__.py with a patched version that makes C extension
# loading non-fatal — PyPI libtorchaudio.so is CUDA 12.x-compiled and ABI-incompatible
# with NGC's CUDA 13.1 torch. qwen_tts only uses torchaudio.compliance.kaldi (pure
# Python/torch), so skipping the C extension is safe.
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.txt \
    && pip install torchaudio==2.10.0 --no-deps \
    && python3 -c "\
import site, os, shutil;\
[shutil.copy('/tmp/torchaudio_ext_patch.py', p) or print('Patched', p)\
 for sp in site.getsitepackages()\
 for p in [os.path.join(sp, 'torchaudio', '_extension', '__init__.py')]\
 if os.path.exists(p)]"

RUN pip install runpod boto3 requests nvidia-ml-py \
    && git clone --depth 1 https://github.com/QwenLM/Qwen3-TTS.git /tmp/qwen3-tts \
    && echo "=== qwen3-tts pinned commit: $(git -C /tmp/qwen3-tts rev-parse HEAD) ===" \
    && pip install --no-deps /tmp/qwen3-tts \
    && pip install "sox" "onnxruntime" "gradio" \
    && rm -rf /tmp/qwen3-tts

RUN mkdir -p /runpod-volume/models/huggingface /tmp/heard-again \
    && python -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='${MODEL_ID}', cache_dir='/runpod-volume/models/huggingface')" \
    && chmod -R 777 /runpod-volume /tmp/heard-again

COPY app/ ./app/

CMD ["python", "-m", "app.runpod_handler"]
