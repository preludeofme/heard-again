FROM nvcr.io/nvidia/pytorch:25.12-py3

LABEL build.version="2026-05-28.1"

ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1
ENV MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
ENV HF_HOME=/runpod-volume/models/huggingface
ENV TRANSFORMERS_CACHE=/runpod-volume/models/huggingface
ENV TORCH_HOME=/runpod-volume/models/torch
ENV MODEL_CACHE_DIR=/runpod-volume/models
ENV TEMP_DIR=/tmp/heard-again
ENV DEFAULT_AUDIO_FORMAT=wav

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    sox \
    libsox-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# flash-attn is pre-installed in the NGC base image, so we skip it to prevent build errors
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.txt \
    && pip install runpod boto3 requests nvidia-ml-py \
    && git clone --depth 1 https://github.com/QwenLM/Qwen3-TTS.git /tmp/qwen3-tts \
    && echo "=== qwen3-tts pinned commit: $(git -C /tmp/qwen3-tts rev-parse HEAD) ===" \
    && pip install --no-deps /tmp/qwen3-tts \
    && pip install "transformers==4.57.3" "accelerate==1.12.0" "sox" "onnxruntime" "gradio" \
    && rm -rf /tmp/qwen3-tts
# qwen_tts is installed with --no-deps to prevent it from upgrading torchaudio.
# NGC 25.12 ships torchaudio pre-installed at a version matched to its torch build.
# Allowing qwen_tts to pull torchaudio from PyPI installs an incompatible version
# (2.11.0 vs torch 2.10.0) causing undefined symbol errors at runtime.

RUN mkdir -p /runpod-volume/models/huggingface /tmp/heard-again \
    && python -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='${MODEL_ID}', cache_dir='/runpod-volume/models/huggingface')" \
    && chmod -R 777 /runpod-volume /tmp/heard-again

COPY app/ ./app/

CMD ["python", "-m", "app.runpod_handler"]
