FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1
ENV MODEL_ID=Qwen/Qwen3-TTS-12Hz-0.6B-Base
ENV HF_HOME=/runpod-volume/models/huggingface
ENV TRANSFORMERS_CACHE=/runpod-volume/models/huggingface
ENV TORCH_HOME=/runpod-volume/models/torch
ENV MODEL_CACHE_DIR=/runpod-volume/models
ENV TEMP_DIR=/tmp/heard-again
ENV DEFAULT_AUDIO_FORMAT=wav

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    wget \
    curl \
    ffmpeg \
    libsndfile1 \
    sox \
    libsox-dev \
    build-essential \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.txt \
    && pip install runpod boto3 requests https://github.com/Dao-AILab/flash-attention/releases/download/v2.6.3/flash_attn-2.6.3+cu123torch2.4cxx11abiFALSE-cp311-cp311-linux_x86_64.whl \
    && git clone --depth 1 https://github.com/QwenLM/Qwen3-TTS.git /tmp/qwen3-tts \
    && echo "=== qwen3-tts pinned commit: $(git -C /tmp/qwen3-tts rev-parse HEAD) ===" \
    && pip install /tmp/qwen3-tts \
    && rm -rf /tmp/qwen3-tts
# NOTE: qwen_tts is installed from latest main. Once a known-good commit is confirmed,
# pin it with: git -C /tmp/qwen3-tts checkout <COMMIT_HASH> before pip install.

RUN mkdir -p /runpod-volume/models/huggingface /tmp/heard-again \
    && python -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='${MODEL_ID}', cache_dir='/runpod-volume/models/huggingface')" \
    && chmod -R 777 /runpod-volume /tmp/heard-again

COPY app/ ./app/

CMD ["python", "-m", "app.runpod_handler"]
