{
  "name": "heard-again",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002 -H 0.0.0.0 --webpack",
    "dev:debug": "NODE_ENV=development DEBUG=* next dev -p 3002 -H 0.0.0.0 --webpack",
    "build": "next build --webpack",
    "start": "next build && next start -p 3002 -H 0.0.0.0",
    "start:tts": "cd tts-service && ./start.sh",
    "start:voice": "docker compose -f docker-compose.voice.yml up -d",
    "stop:voice": "docker compose -f docker-compose.voice.yml down",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@xyflow/react": "^12.10.1",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "formidable": "^3.5.4",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "notistack": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/formidable": "^3.5.0",
    "@types/node": "25.5.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0"
  }
}
