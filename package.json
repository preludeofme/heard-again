{
  "name": "heard-again-root",
  "version": "1.0.0",
  "private": true,
  "description": "Heard Again - Family Story Preservation Platform",
  "scripts": {
    "dev": "./Scripts/start-dev.sh --live",
    "dev_worktree": "./Scripts/start-dev-worktree.sh --live",
    "build": "npm --workspace UI run build",
    "type-check": "npm --workspace UI run typecheck",
    "start": "npm --workspace UI run start",
    "test": "npm --workspace UI run test",
    "test:watch": "npm --workspace UI run test:watch",
    "test:coverage": "npm --workspace UI run test:coverage",
    "lint": "npm --workspace UI run lint",
    "start:tts": "cd TTS && ./start.sh",
    "start:voice": "docker compose --profile with-tts up -d",
    "stop:voice": "docker compose --profile with-tts down",
    "sonar:scan": "sonar-scanner -Dproject.settings=sonar-project.properties",
    "sonar:start": "docker compose -f docker-compose.sonarqube.yml up -d",
    "sonar:stop": "docker compose -f docker-compose.sonarqube.yml down",
    "sonar:logs": "docker logs sonarqube",
    "db:generate": "npm --workspace UI run db:generate",
    "db:migrate": "npm --workspace UI run db:migrate",
    "db:push": "npm --workspace UI run db:push",
    "db:studio": "npm --workspace UI run db:studio",
    "db:seed": "npm --workspace UI run db:seed",
    "db:reset-family": "node Scripts/reset-family.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "install:all": "npm install --workspaces",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:cleanup": "node e2e/cleanup-test-data.mjs",
    "e2e:test": "playwright test",
    "e2e:test:ui": "playwright test --ui",
    "verify": "./Scripts/ci-verify.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@trigger.dev/build": "^4.5.0",
    "@types/archiver": "^7.0.0",
    "prisma": "^6.19.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google-cloud/storage": "^7.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@prisma/client": "^6.19.3",
    "@trigger.dev/sdk": "^4.5.0",
    "@types/dompurify": "^3.0.5",
    "archiver": "^8.0.0",
    "canvas": "^3.2.3",
    "isomorphic-dompurify": "^3.14.0",
    "jsqr": "^1.4.0",
    "next-auth": "^4.24.13",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "workspaces": [
    "UI"
  ],
  "overrides": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "systeminformation": "^5.31.6",
    "next": "16.2.6",
    "protobufjs": "^7.0.0"
  }
}
