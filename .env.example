# ============================================
# Heard Again - Root Environment Configuration
# ============================================

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
POSTGRES_PASSWORD="your_postgres_password_here"

# NextAuth
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="https://your-domain.com"

# OAuth Providers
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Service Communication Tokens (Shared)
# CHAT_SERVICE_SECRET/CHAT_SERVICE_URL are optional. The AI chat/RAG service has been
# removed from this branch and is being developed separately for future reintroduction.
# Leaving these unset is safe — dependent code (asset RAG ingestion hooks) no-ops gracefully.
CHAT_SERVICE_SECRET="your_chat_service_secret_here"
CHAT_SERVICE_URL="http://localhost:4778"
TTS_SERVICE_SECRET="your_tts_service_secret_here"

# Google Maps (for location search when adding stories)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Service URLs
UI_URL="https://your-ui-domain.com"
TTS_SERVICE_URL="http://localhost:4779"

# Storage
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"
UPLOAD_BASE_URL="https://your-domain.com/api/assets"

# Cloudflare (Optional)
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id_here"
CLOUDFLARE_ZONE_ID="your_cloudflare_zone_id_here"
CLOUDFLARE_TUNNEL_TOKEN="your_cloudflare_tunnel_token_here"

# Logging & Environment
NODE_ENV="development"
LOG_LEVEL="info"

STRIPE_ADMIN="your_stripe_admin_key_here"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_signing_secret_here"
RESEND_API_KEY="your_resend_api_key_here"
SUPPORT_EMAIL="support@example.com"


CLOUDFLARE_BUCKET_TOKEN="your_cloudflare_bucket_token_here"
CLOUDFLARE_BUCKET_ACCESS_ID="your_cloudflare_bucket_access_id_here"
CLOUDFLARE_BUCKET_SECRET_KEY="your_cloudflare_bucket_secret_key_here"
CLOUDFLARE_BUCKET_JURIDICTION_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

RUNPOD_API_KEY="your_runpod_api_key_here"

# ─── Trigger.dev (task queue for exports, narration, GEDCOM import) ─────────
# Self-hosted instance is started automatically by npm run dev via Docker.
# First run: visit http://localhost:3030 → create account → copy token below.
# (Login magic-link appears in logs/trigger-app.log — no email provider needed)
TRIGGER_API_URL="http://localhost:3030"
TRIGGER_SECRET_KEY="your_trigger_personal_access_token_here"
