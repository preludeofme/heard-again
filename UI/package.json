    "@emotion/styled": "^11.14.1",
    "@google-cloud/storage": "^7.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.6.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@xyflow/react": "^12.10.1",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "express-rate-limit": "^8.3.1",
    "file-type": "^21.3.4",
    "fluent-ffmpeg": "^2.1.3",
    "formidable": "^3.5.4",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "music-metadata": "^7.14.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "notistack": "^3.0.2",
    "otplib": "^13.4.0",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.33.5",
    "speakeasy": "^2.0.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.4",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
