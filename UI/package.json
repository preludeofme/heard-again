{
  "name": "heard-again",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4777 -H 0.0.0.0 --webpack",
    "dev:debug": "NODE_ENV=development DEBUG=* next dev -p 4777 -H 0.0.0.0 --webpack",
    "build": "next build --webpack",
    "start": "next build && next start -p 4777 -H 0.0.0.0",
    "start:tts": "cd ../TTS && ./start.sh",
    "start:voice": "docker compose -f docker-compose.voice.yml up -d",
    "stop:voice": "docker compose -f docker-compose.voice.yml down",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "sonar:scan": "sonar-scanner -Dproject.settings=sonar-project.properties",
    "sonar:start": "docker compose -f docker-compose.sonarqube.yml up -d",
    "sonar:stop": "docker compose -f docker-compose.sonarqube.yml down",
    "sonar:logs": "docker logs sonarqube",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx ../prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
