// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Chat Sessions
model ChatSession {
  id        String   @id @default(cuid())
  workspaceId String
  personId  String
  userId    String
  title     String?
  status    SessionStatus @default(ACTIVE)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages ChatMessage[]

  @@map("chat_sessions")
}

enum SessionStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// Chat Messages
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// Persona Profiles
model PersonaProfile {
  id                String   @id @default(cuid())
  personId          String   @unique
  workspaceId       String
  version           Int      @default(1)
  status            PersonaStatus @default(DRAFT)
  writingStyle      Json     // Stores PersonaProfile['writingStyle']
  knownFacts        Json     // Stores PersonaFact[]
  relationships     Json     // Stores Relationship[]
  systemPrompt      String
  responseGuidelines Json    // Stores string[]
  customInstructions Json    // Stores PersonaProfile['customInstructions']
  documentSampleCount Int    @default(0)
  confidenceScore   Float    @default(0.0)
  lastUpdated       DateTime @default(now())
  createdAt         DateTime @default(now())

  @@map("persona_profiles")
}

enum PersonaStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Documents
model Document {
  id             String          @id @default(cuid())
  workspaceId    String
  personId       String?
  title          String
  content        String?
  documentType   DocumentType
  source         String
  metadata       Json            @default("{}")
  status         DocumentStatus  @default(UPLOADED)
  embeddingStatus EmbeddingStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  chunks DocumentChunk[]

  @@map("documents")
}

enum DocumentType {
  STORY
  LETTER
  DIARY
  PHOTO_CAPTION
  AUDIO_TRANSCRIPT
  DOCUMENT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum EmbeddingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Document Chunks
model DocumentChunk {
  id           String   @id @default(cuid())
  documentId   String
  chunkIndex   Int
  content      String
  metadata     Json     @default("{}")
  embedding    Float[] // Vector embedding
  embeddingModel String?
  createdAt    DateTime @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@map("document_chunks")
}

// Ingestion Jobs
model IngestionJob {
  id           String            @id @default(cuid())
  documentId   String
  workspaceId  String
  userId       String
  type         IngestionJobType
  status       IngestionJobStatus @default(QUEUED)
  priority     JobPriority        @default(NORMAL)
  progress     Json              @default("{}")
  config       Json              @default("{}")
  error        Json?
  metadata     Json              @default("{}")
  createdAt    DateTime          @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  updatedAt    DateTime          @updatedAt

  @@map("ingestion_jobs")
}

enum IngestionJobType {
  DOCUMENT_PROCESSING
  TEXT_EXTRACTION
  CHUNKING
  EMBEDDING_GENERATION
  INDEXING
}

enum IngestionJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Workspace Context (for tenant isolation)
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workspaces")
}

// User Workspace Memberships
model UserWorkspace {
  id         String   @id @default(cuid())
  userId     String
  workspaceId String
  role       WorkspaceRole @default(MEMBER)
  permissions Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, workspaceId])
  @@map("user_workspaces")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// Audit Logs for security and compliance
model AuditLog {
  id         String   @id @default(cuid())
  workspaceId String
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
