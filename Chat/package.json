{
  "name": "heard-again-chat-system",
  "version": "1.0.0",
  "description": "Phase 1 Family-History Conversational AI System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev -p 4778",
    "build": "next build",
    "start": "next start -p 4778",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "migration:dev": "prisma migrate dev",
    "migration:deploy": "prisma migrate deploy",
    "migration:generate": "prisma generate",
    "ingestion:worker": "ts-node src/workers/ingestion-worker.ts",
    "docker:build": "docker build -t chat-system -f docker/Dockerfile .",
    "docker:run": "docker-compose -f docker/docker-compose.yml up"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "axios": "^1.14.0",
    "bullmq": "^4.0.0",
    "chromadb": "^1.7.0",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "mammoth": "^1.6.0",
    "marked": "^9.0.0",
    "next": "^14.0.0",
    "ollama": "^0.5.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "redis": "^4.6.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.7",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.5.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "chat",
    "ai",
    "family-history",
    "llm",
    "rag",
    "ollama",
    "chromadb"
