generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ACCOUNT & IDENTITY MODELS
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  // null for OAuth users
  oauthProvider String? // google, github, etc.
  oauthId   String?
  
  // NextAuth compatibility (OAuth profile data)
  name          String?
  image         String?
  emailVerified DateTime?
  
  displayName String?
  avatarUrl String?
  
  status    UserStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?
  
  // Relations
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  memberships     Membership[]
  createdStories  Story[] @relation("StoryCreator")
  comments        StoryComment[]
  voiceProfiles   VoiceProfile[]
  createdPeople   Person[]
  uploadedAssets  Asset[]
  notifications   Notification[]
  importJobs      ImportJob[]
  exportJobs      ExportJob[]
  collections     Collection[]
  collectionStories CollectionStory[]
  voiceConsents     VoiceConsent[]
  favorites         UserStoryFavorite[]
  invitedWorkspaceInvites WorkspaceInvite[]
  
  // NextAuth relations
  accounts  Account[]
  sessions  Session[]
  
  defaultWorkspaceId String?
  defaultWorkspace   Workspace? @relation("UserDefaultWorkspace", fields: [defaultWorkspaceId], references: [id])
  
  @@index([email])
  @@index([oauthProvider, oauthId])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // for subdomain routing: slug.heardagain.com
  
  ownerId     String
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  
  planType    PlanType @default(FREE)
  deploymentMode DeploymentMode @default(LOCAL)
  
  // Billing
  billingCustomerId String?
  subscription  Subscription?
  
  // Features & Entitlements (cached from subscription for fast access)
  tunnelEnabled     Boolean @default(false)
  cloudGpuEnabled   Boolean @default(false)
  storageQuotaBytes BigInt @default(0)
  memberQuota       Int @default(1)
  generationMinuteQuota Int @default(0)
  
  status      WorkspaceStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  members     Membership[]
  instances   Instance[]
  people      Person[]
  stories     Story[]
  voiceProfiles VoiceProfile[]
  assets      Asset[]
  auditLogs   AuditLog[]
  collections Collection[]
  invites     WorkspaceInvite[]
  importJobs  ImportJob[]
  exportJobs  ExportJob[]
  voiceConsents VoiceConsent[]
  familyUnits FamilyUnit[]
  defaultForUsers User[] @relation("UserDefaultWorkspace")
  
  @@index([ownerId])
  @@index([slug])
}

enum PlanType {
  FREE              // Local self-hosted
  CONNECTED         // Connected self-hosted with tunnel
  HYBRID            // Connected + cloud GPU
  CLOUD             // Fully cloud hosted
}

enum DeploymentMode {
  LOCAL     // Self-hosted, local only
  TUNNELED  // Self-hosted with HeardAgain.com tunnel
  CLOUD     // Fully hosted by Heard Again
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

model Membership {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role        WorkspaceRole @default(VIEWER)
  
  invitedById String?
  invitedAt   DateTime?
  joinedAt    DateTime @default(now())
  
  status      MembershipStatus @default(ACTIVE)
  
  // Permissions override (optional, null means use role defaults)
  canCreateStories  Boolean?
  canEditStories    Boolean?
  canDeleteStories  Boolean?
  canManagePeople   Boolean?
  canManageVoices   Boolean?
  canManageBilling  Boolean?
  canManageMembers  Boolean?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum WorkspaceRole {
  OWNER     // Full control including billing
  ADMIN     // Can manage content and members, not billing
  EDITOR    // Can create and edit stories
  VIEWER    // Can view and listen only
  LEGACY    // Extended family - limited upload access
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ImportSourceType {
  GEDCOM
  JSON
  CSV
  MANUAL_MIGRATION
}

enum ExportType {
  PDF
  JSON
  ZIP
  GEDCOM
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ConsentType {
  SELF
  FAMILY_ATTESTATION
  ESTATE_REPRESENTATIVE
  OTHER
}

model PersonName {
  id        String   @id @default(uuid())

  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  nameType  PersonNameType @default(BIRTH)
  givenName String
  surname   String?
  prefix    String?
  suffix    String?
  nickname  String?
  isPrimary Boolean @default(false)

  startDate DateTime?
  endDate   DateTime?

  gedcomXref String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId, isPrimary])
  @@unique([personId, gedcomXref])
}

enum PersonNameType {
  BIRTH
  MARRIED
  AKA
  RELIGIOUS
  OTHER
}

model PersonEvent {
  id        String   @id @default(uuid())

  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  eventType PersonEventType
  eventDate DateTime?
  place     String?
  description String?
  sourceCitation String?
  isPrimary Boolean @default(false)

  gedcomXref String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId, eventType, eventDate])
  @@unique([personId, gedcomXref])
}

enum PersonEventType {
  BIRTH
  BAPTISM
  DEATH
  BURIAL
  CREMATION
  MARRIAGE
  DIVORCE
  RESIDENCE
  OCCUPATION
  EDUCATION
  CUSTOM
}

model FamilyUnit {
  id          String   @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  gedcomXref  String?

  // Normalized parent relationships (replaces husbandId/wifeId)
  parents     FamilyParent[]
  children    FamilyChild[]

  marriageDate DateTime?
  marriagePlace String?
  divorceDate DateTime?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@unique([workspaceId, gedcomXref])
}

model FamilyParent {
  id       String   @id @default(uuid())

  familyId String
  family   FamilyUnit @relation(fields: [familyId], references: [id], onDelete: Cascade)

  parentId String
  parent   Person     @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Relationship type to this family (biological, adoptive, step, etc.)
  relationshipType ParentRelationshipType @default(BIOLOGICAL)

  // Display order in the family
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@unique([familyId, parentId])
  @@index([parentId])
}

enum ParentRelationshipType {
  BIOLOGICAL
  ADOPTIVE
  STEP
  FOSTER
  GUARDIAN
  PARTNER        // Non-married partner
  OTHER
}

model FamilyChild {
  id         String   @id @default(uuid())

  familyId   String
  family     FamilyUnit @relation(fields: [familyId], references: [id], onDelete: Cascade)

  childId    String
  child      Person   @relation(fields: [childId], references: [id], onDelete: Cascade)

  relationshipType ChildRelationshipType @default(BIOLOGICAL)
  sortOrder  Int @default(0)

  createdAt  DateTime @default(now())

  @@unique([familyId, childId])
  @@index([childId])
}

enum ChildRelationshipType {
  BIOLOGICAL
  ADOPTED
  STEP
  FOSTER
  GUARDIAN
}

model PersonExternalRef {
  id          String   @id @default(uuid())

  personId    String
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  system      ExternalRefSystem
  externalId  String
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([personId])
  @@unique([personId, system, externalId])
}

enum ExternalRefSystem {
  GEDCOM
  GRAMPS
  ROOTSMAGIC
  FAMILYSEARCH
  ANCESTRY
  MYHERITAGE
  OTHER
}

enum GenerationMode {
  DEFAULT
  LOCAL
  CLOUD
  HYBRID
}

enum NotificationType {
  INVITE_RECEIVED
  INVITE_ACCEPTED
  STORY_COMMENT
  STORY_SHARED
  GENERATION_COMPLETED
  GENERATION_FAILED
}

enum PersonType {
  FAMILY
  FRIEND
  MENTOR
  COLLEAGUE
  OTHER
}

model Instance {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  type        InstanceType
  status      InstanceStatus @default(REGISTERING)
  version     String
  
  // Deployment config
  computeMode ComputeMode @default(LOCAL)
  dataMode     DataMode @default(LOCAL)
  
  // Tunnel config (for CONNECTED/HYBRID modes)
  tunnelEnabled   Boolean @default(false)
  tunnelSubdomain String?
  tunnelToken     String? // For secure tunnel authentication
  tunnelTokenExpiresAt DateTime?
  lastAuthenticatedAt  DateTime?
  
  // Health/status tracking
  lastErrorAt      DateTime?
  lastErrorMessage String?
  
  // Connection tracking
  registeredAt    DateTime @default(now())
  lastHeartbeatAt DateTime?
  
  // Cloud deployment config (for CLOUD mode)
  region          String?
  hostUrl         String?
  
  metadata        Json?    // Flexible config storage
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([workspaceId])
  @@index([tunnelSubdomain])
}

enum InstanceType {
  LOCAL     // User's own hardware
  CLOUD     // Heard Again hosted
  HYBRID    // Local data, cloud compute
}

enum InstanceStatus {
  REGISTERING
  ACTIVE
  UPDATING
  OFFLINE
  DECOMMISSIONED
}

enum ComputeMode {
  LOCAL     // GPU on local machine
  CLOUD     // Cloud GPU only
  HYBRID    // Prefer local, fallback to cloud
}

enum DataMode {
  LOCAL     // Local storage only
  CLOUD     // Cloud storage only
  SYNCED    // Local + cloud backup
}

model Subscription {
  id          String   @id @default(uuid())
  
  workspaceId String   @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  planId      String   // Reference to plan definition
  plan        Plan     @relation(fields: [planId], references: [id])
  
  // Billing
  billingStatus   BillingStatus @default(TRIAL)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  
  renewalDate     DateTime?
  cancelledAt     DateTime?
  
  // Usage tracking
  generationMinutesUsed Int @default(0)
  storageBytesUsed      BigInt @default(0)
  lastBillingResetAt    DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([workspaceId])
  @@index([stripeSubscriptionId])
}

model Plan {
  id          String   @id @default(cuid())
  
  name        String   @unique
  planType    PlanType
  
  // Pricing
  priceMonthlyCents   Int
  priceYearlyCents    Int?
  
  // Entitlements
  tunnelEnabled     Boolean @default(false)
  cloudGpuEnabled   Boolean @default(false)
  cloudStorageEnabled Boolean @default(false)
  generationMinutesIncluded Int @default(0)
  storageQuotaBytes BigInt @default(0)
  memberQuota       Int @default(1)
  voiceProfileQuota Int @default(0)
  
  // Features
  prioritySupport   Boolean @default(false)
  advancedAnalytics Boolean @default(false)
  
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  subscriptions     Subscription[]
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

// ============================================
// CONTENT MODELS
// ============================================

model Person {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Basic info
  firstName   String
  lastName    String?
  displayName String?  // Override for how they appear in stories
  gedcomXref  String?  // Original GEDCOM @I...@ identifier for round-trip imports/exports
  sex         GedcomSex?
  
  // Dates
  birthDate   DateTime?
  deathDate   DateTime?
  isDeceased  Boolean @default(false)
  
  // Bio
  bio         String?  // Markdown supported
  avatarAssetId String?
  avatarAsset   Asset? @relation("PersonAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  
  // Additional name fields for genealogy
  middleName  String?
  nickname    String?
  maidenName  String?
  suffix      String? // Jr, Sr, III
  
  // Person categorization
  personType  PersonType @default(FAMILY) // family, friend, other
  
  // Metadata
  tags        String[] // For categorization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
  
  // Relations
  storiesAsSubject Story[] @relation("StorySubject")
  storiesAsSpeaker Story[] @relation("StorySpeaker")
  voiceProfiles    VoiceProfile[]
  voiceConsents    VoiceConsent[]
  names            PersonName[]
  events           PersonEvent[]
  externalRefs     PersonExternalRef[]
  parentInFamilies FamilyParent[]
  familyChildLinks  FamilyChild[]
  
  @@index([workspaceId])
  @@index([firstName, lastName])
  @@index([maidenName])
  @@unique([workspaceId, gedcomXref])
}

enum GedcomSex {
  M
  F
  U
  X
}

model Story {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  title       String
  content     String   // Markdown text
  
  // Story classification
  storyType   StoryType @default(MEMORY)
  
  // People involved
  subjectId   String?  // Who the story is about
  subject     Person?  @relation("StorySubject", fields: [subjectId], references: [id])
  
  speakerId   String?  // Who is telling the story (if different from subject)
  speaker     Person?  @relation("StorySpeaker", fields: [speakerId], references: [id])
  
  // AI Generation
  generatedAudioAssetId String?  // Link to generated TTS audio
  generatedAudioAsset   Asset? @relation("StoryGeneratedAudio", fields: [generatedAudioAssetId], references: [id], onDelete: SetNull)
  voiceProfileId String?  // Which voice was used
  voiceProfile   VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)
  
  // Story preview
  excerpt     String?  // For cards and list views
  
  // Timeline
  storyDate   DateTime? // When the story took place
  storyDatePrecision DatePrecision @default(EXACT)
  
  // Metadata
  tags        String[]
  status      StoryStatus @default(DRAFT)
  isPinned    Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("StoryCreator", fields: [createdById], references: [id])
  
  // Relations
  assets      StoryAsset[]
  comments    StoryComment[]
  favorites   UserStoryFavorite[]
  collections CollectionStory[]
  generationJobs VoiceGenerationJob[]
  
  @@index([workspaceId])
  @@index([subjectId])
  @@index([speakerId])
  @@index([storyDate])
  @@index([status])
}

enum StoryType {
  MEMORY      // Personal recollection
  INTERVIEW   // Q&A format
  LETTER      // Written correspondence
  DOCUMENT    // Historical document
  TRIBUTE     // Memorial/remembrance
  PODCAST     // Audio story
}

enum DatePrecision {
  EXACT
  YEAR_MONTH  // Know year and month only
  YEAR        // Know year only
  DECADE      // 1990s, etc.
  APPROXIMATE // "Around 1950"
}

enum StoryStatus {
  DRAFT
  REVIEW      // Pending approval
  PUBLISHED
  ARCHIVED
}

model StoryComment {
  id          String   @id @default(uuid())
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  content     String
  
  // Threading support
  parentId    String?
  parent      StoryComment? @relation("CommentThread", fields: [parentId], references: [id])
  replies     StoryComment[] @relation("CommentThread")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([storyId])
  @@index([userId])
  @@index([parentId])
}

// ============================================
// ASSET / FILE MODELS
// ============================================

model Asset {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // File info
  filename    String
  originalName String
  mimeType    String
  sizeBytes   BigInt
  
  // Storage
  storageType StorageType
  storagePath String   // Path/URL to actual file
  storageBucket String? // For object storage
  
  // Asset type
  assetType   AssetType
  
  // Metadata (extracted)
  durationSeconds Float? // For audio/video
  width       Int?       // For images/video
  height      Int?       // For images/video
  transcript  String?    // For audio ( Whisper output)
  metadata    Json?      // EXIF, ID3, etc.
  
  // Processing status
  processingStatus ProcessingStatus @default(PENDING)
  processingError String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  
  // Relations
  storyAssets StoryAsset[]
  personAvatarFor Person[] @relation("PersonAvatar")
  voiceProfileSources VoiceProfile[] @relation("VoiceProfileSourceAsset")
  generatedAudioForStories Story[] @relation("StoryGeneratedAudio")
  voiceGenerationOutputs VoiceGenerationJob[] @relation("VoiceGenerationOutputAsset")
  importSources ImportJob[] @relation("ImportSourceAsset")
  exportOutputs ExportJob[] @relation("ExportOutputAsset")
  modelArtifactFor VoiceProfile[]
  
  @@index([workspaceId])
  @@index([assetType])
  @@index([processingStatus])
}

// ============================================
// USER ENGAGEMENT MODELS (Favorites & Collections)
// ============================================

model UserStoryFavorite {
  id          String   @id @default(uuid())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

enum StorageType {
  LOCAL       // Local filesystem
  S3          // Object storage
  CLOUDFLARE_R2
  AZURE_BLOB
  GOOGLE_CLOUD
}

enum AssetType {
  AUDIO       // Recording, music
  VIDEO       // Video recording
  IMAGE       // Photo, scan
  DOCUMENT    // PDF, Word, etc.
  TRANSCRIPT  // Generated text from audio
  GENERATED_AUDIO // AI-generated TTS output
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Junction table: Stories <-> Assets
model StoryAsset {
  id          String   @id @default(uuid())
  
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  // How the asset is used in the story
  assetRole   AssetRole @default(ATTACHMENT)
  sortOrder   Int @default(0)
  caption     String?
  
  createdAt   DateTime @default(now())
  
  @@unique([storyId, assetId])
  @@index([storyId])
  @@index([assetId])
}

enum AssetRole {
  PRIMARY     // Main content (e.g., the recording)
  ATTACHMENT  // Supporting file
  TRANSCRIPT  // Text version
  THUMBNAIL   // Preview image
}

// ============================================
// VOICE / TTS MODELS
// ============================================

model VoiceProfile {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Who this voice represents
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  
  name        String   // e.g., "Grandpa Buck"
  description String?  // How they talked
  
  // External service reference (TTS engine's profile ID)
  externalId  String?  // e.g., TTS service's profile ID (no FK constraint)
  
  // Voice data (stored as file reference)
  modelArtifactAssetId String?  // Path to .pt checkpoint file via Asset
  modelArtifactAsset   Asset? @relation(fields: [modelArtifactAssetId], references: [id], onDelete: SetNull)
  modelType   VoiceModelType @default(QWEN3_BASE)
  
  // Engine metadata for multi-engine support
  engineName   String?   // e.g., "qwen3", "chatterbox"
  engineVersion String?   // e.g., "1.7B-base"
  
  // Source reference (if cloned from audio)
  sourceAssetId String?
  sourceAsset   Asset? @relation("VoiceProfileSourceAsset", fields: [sourceAssetId], references: [id], onDelete: SetNull)
  sourceTranscript String? // Text of the reference recording
  
  // Style parameters (stored as JSON for flexibility)
  styleParams Json?    // { temperature, top_p, top_k, repetition_penalty, etc. }
  
  // Metadata
  isDefault   Boolean @default(false) // Default voice for this person
  isCloned    Boolean @default(true) // vs. designed voice
  status      VoiceStatus @default(READY)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  stories     Story[]
  generationJobs VoiceGenerationJob[]
  voiceConsents VoiceConsent[]
  
  @@index([workspaceId])
  @@index([personId])
  @@index([createdById])
  @@index([externalId])
}

enum VoiceModelType {
  QWEN3_BASE      // Cloned from real audio
  QWEN3_DESIGN    // Designed from text description
}

enum VoiceStatus {
  TRAINING
  READY
  ERROR
  DISABLED
}

model VoiceGenerationJob {
  id          String   @id @default(uuid())
  
  voiceProfileId String
  voiceProfile   VoiceProfile @relation(fields: [voiceProfileId], references: [id], onDelete: Cascade)
  
  storyId     String?
  story       Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)
  
  // Input
  text        String
  styleOverride Json?  // Override style params for this generation
  
  // Generation mode (for hybrid/local/cloud decisions)
  generationMode GenerationMode @default(DEFAULT)
  
  // Job status
  status      GenerationStatus @default(QUEUED)
  priority    Int @default(5)   // 1-10, higher = more priority
  
  // Processing
  queuedAt    DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  
  // Results
  outputAssetId String?
  outputAsset   Asset? @relation("VoiceGenerationOutputAsset", fields: [outputAssetId], references: [id], onDelete: SetNull)
  errorMessage  String?
  
  // Cloud tracking (for hybrid/cloud modes)
  cloudJobId  String?  // External job reference
  computeInstance String? // Which instance processed it
  
  // Usage
  durationSeconds Float? // Output audio length
  computeTimeSeconds Float? // Processing time
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([voiceProfileId])
  @@index([status])
  @@index([queuedAt])
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// AUDIT & SECURITY
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  actorId     String?  // User who performed action (null for system)
  actorType   ActorType
  
  action      String   // e.g., "story.create", "voice.generate", "member.invite"
  resourceType String  // e.g., "story", "voice", "member"
  resourceId  String?
  
  // Request context
  ipAddress   String?
  userAgent   String?
  
  // Change details
  beforeState Json?
  afterState  Json?
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@index([workspaceId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

enum ActorType {
  USER
  SYSTEM
  API_KEY
  WEBHOOK
}

// ============================================
// INVITATION & COLLABORATION MODELS
// ============================================

model WorkspaceInvite {
  id          String   @id @default(uuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  email       String
  role        WorkspaceRole @default(VIEWER)

  invitedById String
  invitedBy   User     @relation(fields: [invitedById], references: [id])

  token       String   @unique
  status      InviteStatus @default(PENDING)

  expiresAt   DateTime
  acceptedAt  DateTime?
  declinedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

// ============================================
// IMPORT/EXPORT WORKFLOW MODELS
// ============================================

model ImportJob {
  id            String   @id @default(uuid())

  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sourceType    ImportSourceType
  sourceAssetId String?
  sourceAsset   Asset?   @relation("ImportSourceAsset", fields: [sourceAssetId], references: [id], onDelete: SetNull)

  status        JobStatus @default(PENDING)
  errorMessage  String?

  importedById  String
  importedBy    User      @relation(fields: [importedById], references: [id])

  resultSummary Json?

  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId])
  @@index([status])
}

model ExportJob {
  id            String   @id @default(uuid())

  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  exportType    ExportType
  status        JobStatus @default(PENDING)
  errorMessage  String?

  requestedById String
  requestedBy   User      @relation(fields: [requestedById], references: [id])

  outputAssetId String?
  outputAsset   Asset?    @relation("ExportOutputAsset", fields: [outputAssetId], references: [id], onDelete: SetNull)

  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId])
  @@index([status])
}

// ============================================
// VOICE CONSENT & SAFETY MODELS
// ============================================

model VoiceConsent {
  id                   String   @id @default(uuid())

  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  personId             String?
  person               Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  voiceProfileId       String?
  voiceProfile         VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)

  consentType          ConsentType
  grantedByUserId      String
  grantedByUser        User      @relation(fields: [grantedByUserId], references: [id])

  attestationText      String?
  allowsGeneration     Boolean   @default(true)
  allowsCloudProcessing Boolean  @default(false)
  allowsSharing        Boolean   @default(false)

  recordedAt           DateTime  @default(now())
  revokedAt            DateTime?

  metadata             Json?

  @@index([workspaceId])
  @@index([personId])
  @@index([voiceProfileId])
}

// ============================================
// COLLECTION MODELS
// ============================================

model Collection {
  id          String   @id @default(uuid())
  
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  
  isPinned    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  stories     CollectionStory[]
  
  @@index([workspaceId])
  @@index([createdById])
}

model CollectionStory {
  id           String     @id @default(uuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  
  storyId      String
  story        Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())
  addedById    String
  addedBy      User       @relation(fields: [addedById], references: [id])
  
  @@unique([collectionId, storyId])
  @@index([collectionId])
  @@index([storyId])
}

// ============================================
// NOTIFICATION MODELS
// ============================================

model Notification {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        NotificationType
  title       String
  message     String?
  isRead      Boolean  @default(false)

  resourceType String?
  resourceId   String?

  createdAt   DateTime @default(now())

  @@index([userId, isRead])
}

// ============================================
// NEXTAUTH MODELS (Required for @auth/prisma-adapter)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}
