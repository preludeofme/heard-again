import { NextRequest, NextResponse } from 'next/server'
import { v4 as uuidv4 } from 'uuid'

// Mock database - in production, this would be a real database
const trainingJobs = new Map()
const voiceModels = new Map()

export async function POST(request: NextRequest) {
  console.log('[TRAIN API] Received training request')
  
  try {
    const { userId, samples, language, modelName } = await request.json()
    
    console.log('[TRAIN API] Request data:', { userId, sampleCount: samples?.length, language, modelName })

    // Validate input
    if (!userId || !samples || samples.length === 0 || !modelName) {
      console.error('[TRAIN API] Validation failed:', { hasUserId: !!userId, hasSamples: !!samples, sampleCount: samples?.length, hasModelName: !!modelName })
      return NextResponse.json(
        { error: 'Missing required fields: userId, samples, modelName' },
        { status: 400 }
      )
    }

    // Create training job
    const jobId = uuidv4()
    const modelId = uuidv4()
    
    // Generate GPT-SoVITS compatible model name
    const gptModelName = modelName.replace(/[^a-zA-Z0-9_]/g, '_').toLowerCase()
    const finalModelName = `${gptModelName}_${modelId.slice(0, 8)}`

    const job = {
      id: jobId,
      userId,
      modelId,
      status: 'queued',
      progress: 0,
      currentStage: 'queued',
      samples,
      language: language || 'en',
      modelName: finalModelName,
      originalName: modelName, // Keep original for display
      createdAt: new Date().toISOString(),
      error: null,
    }

    // Store job
    trainingJobs.set(jobId, job)

    // Create model record
    const model = {
      id: modelId,
      userId,
      name: modelName, // Display name
      gptName: finalModelName, // GPT-SoVITS compatible name
      status: 'training',
      modelPath: null,
      metadata: {
        language: language || 'en',
        sampleCount: samples.length,
        createdAt: new Date().toISOString(),
      },
    }

    voiceModels.set(modelId, model)

    // Start training process (in production, this would queue the job)
    console.log(`[TRAIN API] Starting training simulation for job ${jobId}`)
    simulateTraining(jobId)

    console.log(`[TRAIN API] Training job created:`, { jobId, modelId, status: 'queued', modelName: finalModelName })
    
    return NextResponse.json({
      success: true,
      jobId,
      modelId,
      modelName: finalModelName,
      displayName: modelName,
      status: 'queued',
    })
  } catch (error) {
    console.error('[TRAIN API] Training start error:', error)
    return NextResponse.json(
      { error: 'Internal server error' },
      { status: 500 }
    )
  }
}

// Simulate training process
async function simulateTraining(jobId: string) {
  const job = trainingJobs.get(jobId)
  if (!job) return

  const stages = [
    { name: 'preprocessing', duration: 5000, progressEnd: 20 },
    { name: 'asr_processing', duration: 8000, progressEnd: 40 },
    { name: 'training', duration: 15000, progressEnd: 90 },
    { name: 'validation', duration: 3000, progressEnd: 100 },
  ]

  for (const stage of stages) {
    // Update stage
    job.status = 'processing'
    job.currentStage = stage.name
    
    // Simulate progress within stage
    const startProgress = job.progress
    const progressRange = stage.progressEnd - startProgress
    const steps = 10
    
    for (let i = 0; i <= steps; i++) {
      job.progress = startProgress + (progressRange * i) / steps
      await new Promise(resolve => setTimeout(resolve, stage.duration / steps))
    }
  }

  // Complete training
  job.status = 'completed'
  job.progress = 100
  job.currentStage = 'completed'
  job.completedAt = new Date().toISOString()

  // Update model
  const model = voiceModels.get(job.modelId)
  if (model) {
    model.status = 'ready'
    model.modelPath = `/models/${job.modelId}.pth`
  }
}

// Get all jobs (for debugging)
export async function GET() {
  return NextResponse.json({
    jobs: Array.from(trainingJobs.values()),
    models: Array.from(voiceModels.values()),
  })
}
